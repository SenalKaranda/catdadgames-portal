---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;

// Fixed accessibility filters — keys must match those emitted by GameCard.
const a11yOptions = [
  { key: 'keyboard', label: 'Keyboard only OK' },
  { key: 'screen-reader', label: 'Screen reader friendly' },
  { key: 'no-audio', label: 'No audio needed' },
  { key: 'color-not-required', label: 'Color isn’t required' },
] as const;

const sortedTags = [...tags].sort((a, b) => a.localeCompare(b));
---

<section
  aria-label="Filter games"
  data-filter-chips
  class="mb-8 rounded-xl border-2 border-line bg-bg-soft p-5"
>
  <fieldset class="border-0 p-0">
    <legend class="mb-2 text-lg font-bold">Tags</legend>
    <ul class="flex flex-wrap gap-2 p-0">
      {
        sortedTags.map((tag) => (
          <li>
            <button
              type="button"
              data-filter-group="tag"
              data-filter-value={tag}
              aria-pressed="false"
              class="min-h-12 cursor-pointer rounded-full border-2 border-ink-soft bg-bg px-4 py-2 text-base font-semibold text-ink hover:bg-bg-soft aria-pressed:border-ink aria-pressed:bg-ink aria-pressed:text-bg"
            >
              {tag}
            </button>
          </li>
        ))
      }
    </ul>
  </fieldset>

  <fieldset class="mt-5 border-0 p-0">
    <legend class="mb-2 text-lg font-bold">Accessibility</legend>
    <ul class="flex flex-wrap gap-2 p-0">
      {
        a11yOptions.map((opt) => (
          <li>
            <button
              type="button"
              data-filter-group="a11y"
              data-filter-value={opt.key}
              aria-pressed="false"
              class="min-h-12 cursor-pointer rounded-full border-2 border-ink-soft bg-bg px-4 py-2 text-base font-semibold text-ink hover:bg-bg-soft aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-accent-ink"
            >
              {opt.label}
            </button>
          </li>
        ))
      }
    </ul>
  </fieldset>

  <div class="mt-5 flex items-center justify-between gap-3">
    <p data-filter-summary class="text-base" aria-live="polite"></p>
    <button
      type="button"
      data-clear-filters
      hidden
      class="min-h-12 cursor-pointer rounded-full border-2 border-ink-soft bg-bg px-4 py-2 text-base font-semibold text-ink hover:bg-bg"
    >
      Clear filters
    </button>
  </div>
</section>

<p
  data-no-results
  hidden
  class="rounded-xl border-2 border-dashed border-ink-soft p-8 text-center"
>
  No games match those filters.
  <button
    type="button"
    data-clear-filters
    class="ml-2 inline-block min-h-12 cursor-pointer rounded-full border-2 border-ink-soft bg-bg px-4 py-2 text-base font-semibold text-ink"
  >
    Clear filters
  </button>
</p>

<script>
  // Filter logic:
  //   • OR within a group (tag OR tag, a11y OR a11y)
  //   • AND across groups (tags AND a11y)
  //   • URL is the source of truth: ?tags=a,b&a11y=keyboard
  //   • On load + on click, re-read URL → toggle chip pressed + card display
  type Group = 'tag' | 'a11y';

  const PARAM_FOR: Record<Group, string> = {
    tag: 'tags',
    a11y: 'a11y',
  };

  function readState(): Record<Group, Set<string>> {
    const params = new URLSearchParams(window.location.search);
    return {
      tag: parseList(params.get(PARAM_FOR.tag)),
      a11y: parseList(params.get(PARAM_FOR.a11y)),
    };
  }

  function parseList(value: string | null): Set<string> {
    if (!value) return new Set();
    return new Set(
      value
        .split(',')
        .map((v) => v.trim())
        .filter(Boolean),
    );
  }

  function writeState(state: Record<Group, Set<string>>) {
    const params = new URLSearchParams(window.location.search);
    (['tag', 'a11y'] as Group[]).forEach((group) => {
      const values = Array.from(state[group]);
      if (values.length === 0) params.delete(PARAM_FOR[group]);
      else params.set(PARAM_FOR[group], values.join(','));
    });
    const qs = params.toString();
    const newUrl =
      window.location.pathname + (qs ? '?' + qs : '') + window.location.hash;
    window.history.replaceState({}, '', newUrl);
  }

  function applyFilters(state: Record<Group, Set<string>>) {
    const tagFilter = state.tag;
    const a11yFilter = state.a11y;
    const cards =
      document.querySelectorAll<HTMLElement>('[data-game]');
    let visible = 0;
    cards.forEach((card) => {
      const cardTags = (card.dataset.tags ?? '')
        .split(',')
        .filter(Boolean);
      const cardA11y = (card.dataset.a11y ?? '')
        .split(',')
        .filter(Boolean);
      const matchesTag =
        tagFilter.size === 0 ||
        cardTags.some((t) => tagFilter.has(t));
      const matchesA11y =
        a11yFilter.size === 0 ||
        cardA11y.some((a) => a11yFilter.has(a));
      const matches = matchesTag && matchesA11y;
      const li = card.closest('li');
      const target = li ?? card;
      target.toggleAttribute('hidden', !matches);
      if (matches) visible++;
    });

    // Sync chip pressed states + clear/empty UI
    document
      .querySelectorAll<HTMLButtonElement>(
        '[data-filter-group][data-filter-value]',
      )
      .forEach((btn) => {
        const group = btn.dataset.filterGroup as Group;
        const value = btn.dataset.filterValue!;
        btn.setAttribute(
          'aria-pressed',
          String(state[group].has(value)),
        );
      });

    const totalSelected = state.tag.size + state.a11y.size;
    document
      .querySelectorAll<HTMLButtonElement>('[data-clear-filters]')
      .forEach((btn) => {
        btn.hidden = totalSelected === 0;
      });

    const summary = document.querySelector<HTMLElement>(
      '[data-filter-summary]',
    );
    if (summary) {
      if (totalSelected === 0) {
        summary.textContent = '';
      } else {
        summary.textContent = `Showing ${visible} of ${cards.length} games.`;
      }
    }

    const noResults = document.querySelector<HTMLElement>(
      '[data-no-results]',
    );
    const grid = document.querySelector<HTMLElement>('[data-game-grid]');
    if (noResults) noResults.hidden = !(totalSelected > 0 && visible === 0);
    if (grid) grid.hidden = totalSelected > 0 && visible === 0;
  }

  function init() {
    let state = readState();

    document
      .querySelectorAll<HTMLButtonElement>(
        '[data-filter-group][data-filter-value]',
      )
      .forEach((btn) => {
        btn.addEventListener('click', () => {
          const group = btn.dataset.filterGroup as Group;
          const value = btn.dataset.filterValue!;
          if (state[group].has(value)) state[group].delete(value);
          else state[group].add(value);
          writeState(state);
          applyFilters(state);
        });
      });

    document
      .querySelectorAll<HTMLButtonElement>('[data-clear-filters]')
      .forEach((btn) => {
        btn.addEventListener('click', () => {
          state = { tag: new Set(), a11y: new Set() };
          writeState(state);
          applyFilters(state);
        });
      });

    applyFilters(state);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

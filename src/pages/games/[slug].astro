---
import { getCollection, type CollectionEntry } from 'astro:content';
import { marked } from 'marked';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ThumbnailFallback from '@/components/ThumbnailFallback.astro';

export async function getStaticPaths() {
  const games = await getCollection(
    'games',
    ({ data }) => data.status === 'published',
  );
  return games.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'games'>;
}

const { entry } = Astro.props;
const game = entry.data;
const newTab = game.launch_target !== 'same_tab';
const descriptionHtml = await marked.parse(game.description);

const siteUrl = Astro.site?.toString() ?? '';
const pageUrl = new URL(`/games/${game.slug}/`, siteUrl).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Game',
  name: game.title,
  description: game.tagline,
  url: pageUrl,
  applicationCategory: 'Game',
  inLanguage: game.ui_language,
  genre: game.tags,
  playMode: game.players ? 'MultiPlayer' : undefined,
  potentialAction: {
    '@type': 'PlayAction',
    target: game.url,
  },
};

type FlagLabel = { ok: boolean | 'partial' | null; label: string };
const flagRows: FlagLabel[] = [
  { ok: game.accessibility.keyboard_navigation, label: 'Works with keyboard' },
  { ok: game.accessibility.screen_reader, label: 'Works with screen readers' },
  { ok: game.accessibility.high_contrast_mode, label: 'High contrast mode' },
  { ok: game.accessibility.text_resize, label: 'Text can be resized' },
  { ok: game.accessibility.reduced_motion, label: 'Respects reduced motion' },
  {
    ok: game.accessibility.color_only_signals === false,
    label: 'Does not rely on color alone',
  },
  {
    ok: game.accessibility.audio_required === false,
    label: 'No audio required to play',
  },
];

function flagText(ok: boolean | 'partial' | null): string {
  if (ok === true) return 'Yes';
  if (ok === 'partial') return 'Partial';
  return 'No';
}
function flagSymbol(ok: boolean | 'partial' | null): string {
  if (ok === true) return '✓';
  if (ok === 'partial') return '~';
  return '✗';
}
---

<BaseLayout
  title={`${game.title} — ${game.tagline}`}
  description={game.tagline}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
  </Fragment>
  <article class="mx-auto max-w-4xl px-4 py-10">
    <header class="mb-6">
      <h1 class="text-4xl font-bold md:text-5xl">{game.title}</h1>
      <p class="mt-3 text-xl">{game.tagline}</p>
    </header>

    <div
      class="mb-8 overflow-hidden rounded-xl border-2 border-line"
    >
      <ThumbnailFallback
        game={game}
        loading="eager"
        width={1200}
        height={675}
      />
    </div>

    <div class="mb-10 rounded-xl border-2 border-line bg-bg-soft p-6 text-center">
      <a
        href={game.url}
        target={newTab ? '_blank' : undefined}
        rel={newTab ? 'noopener' : undefined}
        class="inline-block w-full max-w-md rounded-lg bg-accent px-8 py-5 text-2xl font-bold text-accent-ink no-underline hover:opacity-90"
      >
        Play {game.title}
      </a>
      <p class="mt-3 text-base">
        {newTab ? 'Opens in a new window.' : 'Opens in this window.'}
      </p>
    </div>

    <section
      aria-labelledby="what-to-expect"
      class="mb-10 rounded-xl border-2 border-line p-6"
    >
      <h2 id="what-to-expect" class="mb-4 text-2xl font-bold">
        What to expect
      </h2>
      <dl class="grid gap-3 sm:grid-cols-3">
        {
          game.players && (
            <div>
              <dt class="text-base font-semibold uppercase tracking-wide text-ink-soft">
                Players
              </dt>
              <dd class="mt-1">{game.players}</dd>
            </div>
          )
        }
        {
          game.duration && (
            <div>
              <dt class="text-base font-semibold uppercase tracking-wide text-ink-soft">
                Duration
              </dt>
              <dd class="mt-1">{game.duration}</dd>
            </div>
          )
        }
        <div>
          <dt class="text-base font-semibold uppercase tracking-wide text-ink-soft">
            Language
          </dt>
          <dd class="mt-1">{game.ui_language === 'en' ? 'English' : game.ui_language}</dd>
        </div>
      </dl>
    </section>

    <section
      aria-labelledby="accessibility-heading"
      class="mb-10 rounded-xl border-2 border-line p-6"
    >
      <h2 id="accessibility-heading" class="mb-4 text-2xl font-bold">
        Accessibility
      </h2>
      <ul class="grid gap-2 sm:grid-cols-2">
        {
          flagRows.map((row) => (
            <li class="flex items-baseline gap-3">
              <span
                class:list={[
                  'inline-flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full text-base font-bold',
                  row.ok === true
                    ? 'bg-ink text-bg'
                    : row.ok === 'partial'
                      ? 'bg-bg-soft text-ink border-2 border-ink'
                      : 'bg-bg-soft text-ink-soft border-2 border-ink-soft',
                ]}
                aria-hidden="true"
              >
                {flagSymbol(row.ok)}
              </span>
              <span>
                <span class="sr-only">{flagText(row.ok)}: </span>
                {row.label}
              </span>
            </li>
          ))
        }
      </ul>
      {
        game.accessibility.notes && (
          <p class="mt-5 border-l-4 border-line pl-4 text-base">
            {game.accessibility.notes}
          </p>
        )
      }
    </section>

    <section aria-labelledby="about-game" class="mb-10">
      <h2 id="about-game" class="mb-3 text-2xl font-bold">About this game</h2>
      <div class="prose" set:html={descriptionHtml} />
    </section>

    {
      game.tags.length > 0 && (
        <section aria-labelledby="tags-heading" class="mb-10">
          <h2 id="tags-heading" class="mb-3 text-xl font-bold">Tags</h2>
          <ul class="flex flex-wrap gap-2">
            {game.tags.map((tag) => (
              <li class="rounded-full border-2 border-ink-soft px-4 py-2 text-base font-semibold">
                {tag}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <p class="mt-12 border-t-2 border-line pt-6">
      <a href="/" class="text-base">← Back to all games</a>
    </p>
  </article>
</BaseLayout>

<style>
  .prose p {
    margin-block: 1em;
  }
  .prose a {
    color: var(--color-accent);
  }
  .prose ul,
  .prose ol {
    padding-left: 1.5em;
    margin-block: 1em;
  }
  .prose li {
    margin-block: 0.4em;
  }
</style>
